# Backend
DATABASE_URL=postgresql://podgap:podgap@db:5432/podgap
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//

# Ollama (local); use host.docker.internal if Ollama runs on host
OLLAMA_HOST=http://ollama:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_LLM_MODEL=llama3.2

# Listen Notes (get key at listennotes.com/api)
LISTEN_NOTES_API_KEY=

# YouTube Data API (get key at console.cloud.google.com)
YOUTUBE_DATA_API_KEY=

# Optional: Google Trends via pytrends (no key), Reddit for trends
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=PodGapAI/1.0

# Auth
JWT_SECRET=change-me-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# App
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
